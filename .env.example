# Copy to .env (gitignored) and fill in the actual values.
# Both must match the values the webapp uses so the apps share the same
# Supabase project, RLS policies, and data.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Base URL of the deployed webapp. The mobile forgot-password flow POSTs to
# `${EXPO_PUBLIC_WEBAPP_URL}/api/auth/send-recovery` so it can reuse the
# same custom email template (link + 6-digit OTP via Resend).
EXPO_PUBLIC_WEBAPP_URL=https://your-vercel-deployment.vercel.app
